# SatyaCheck Environment Variables
# Copy this to .env and fill in your values

# ─── Database ────────────────────────────────
# For development (SQLite - no setup needed)
DEV_MODE=true

# For production (PostgreSQL)
# DEV_MODE=false
# DATABASE_URL=postgresql://user:password@localhost:5432/fakenews_db

# ─── ML Models ───────────────────────────────
MODEL_PATH=multilingual_model.pkl
VECTORIZER_PATH=vectorizer.pkl

# ─── Server ──────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ─── Docker Compose ──────────────────────────
DB_PASSWORD=satyacheck_secure_2024
